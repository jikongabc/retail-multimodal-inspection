# 复制为 .env 后填写仅供本机使用的云端运行配置。
# 不要提交 .env，也不要把密码、API Key 或 Codex 凭据写入仓库。

REMOTE_HOST=<user>@<ssh-host>
REMOTE_PORT=<ssh-port>
REMOTE_BASE=<remote-workspace-dir>
REMOTE_DIR=<remote-project-dir>
REMOTE_PYTHON=<remote-python-command>
REMOTE_MODEL_PATH=<remote-ostrakon-model-dir>
OSTRAKON_PORT=8000

# 使用默认 SSH 登录方式时可留空。
REMOTE_SSH_KEY=<local-private-key-path>
